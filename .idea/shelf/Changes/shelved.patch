+    @Test
+    void uniqueTickPerMetalTimestamp_isEnforced() {
+        MetalEntity m = new MetalEntity();
+        m.setCode("XAG");
+        m.setName("Silver");
+        metalRepo.save(m);
+
+        Instant t = Instant.parse("2026-01-16T00:00:00Z");
+
+        SpotTick5mEntity a = new SpotTick5mEntity();
+        a.setMetal(m);
+        a.setTsUtc(t);
+        a.setAsk(new BigDecimal("100.00"));
+        tickRepo.saveAndFlush(a);
+
+        SpotTick5mEntity b = new SpotTick5mEntity();
+        b.setMetal(m);
+        b.setTsUtc(t);
+        b.setAsk(new BigDecimal("101.00"));
