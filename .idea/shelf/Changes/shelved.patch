+package com.hugoserve.metalbroker.schedulers;
+
+import com.hugoserve.metalbroker.feed.GoldBrokerApiClient;
+import com.hugoserve.metalbroker.proto.MetalRatesProto;
+import com.hugoserve.metalbroker.service.RateStorageService;
+
+import org.springframework.beans.factory.annotation.Value;
+import org.springframework.boot.context.event.ApplicationReadyEvent;
+import org.springframework.context.event.EventListener;
+import org.springframework.scheduling.annotation.Scheduled;
+import org.springframework.stereotype.Component;
+
+import org.springframework.cache.annotation.CacheEvict;
+import static com.hugoserve.metalbroker.config.CacheConfig.CACHE_DB_LATEST;
+
+import java.util.Arrays;
+import java.util.List;
+
+@Component
+public class FeedSchedulers {
+
+    private final GoldBrokerApiClient api;
+    private final RateStorageService storage;
+
+    private final List<String> metals; // MUST be XAU,XAG...
+    private final String currency;
+    private final String unit;
+    private final int retentionDays;
+
+    public FeedSchedulers(GoldBrokerApiClient api,
+                          RateStorageService storage,
+                          @Value("${metalbroker.feed.metals}") String metalsCsv,
+                          @Value("${metalbroker.feed.currency}") String currency,
+                          @Value("${metalbroker.feed.weight-unit}") String unit,
+                          @Value("${metalbroker.feed.intraday-retention-days}") int retentionDays) {
+        this.api = api;
+        this.storage = storage;
+        this.metals = Arrays.stream(metalsCsv.split(","))
+                .map(String::trim)
+                .toList();
+        this.currency = currency;
+        this.unit = unit;
+        this.retentionDays = retentionDays;
+    }
+
+    // ✅ Backfill once at app start: API #2 + API #1
+    @CacheEvict(cacheNames = CACHE_DB_LATEST, allEntries = true)
+    @EventListener(ApplicationReadyEvent.class)
+    public void startupSync() {
+        for (String m : metals) {
+            try {
+                // 1) Backfill intraday window (API #2)
+                MetalRatesProto.SpotPricesResponse intraday = api.fetchIntraday(m, currency, unit);
+                if (intraday != null && intraday.hasEmbedded()) {
+                    var items = intraday.getEmbedded().getItemsList();
+                    if (items != null && !items.isEmpty()) {
+                        storage.upsertIntradayTicks(m, items);
+                    }
+                    // optional: daily candle from API#2 response if you re-enable it later
+                    // storage.upsertLastHistoricalCandleIfPresent(m, intraday);
+                }
+
+                // 2) Fetch latest snapshot once (API #1)
+                MetalRatesProto.SpotPrice latest = api.fetchCurrent(m, currency, unit);
+                if (latest != null) {
+                    storage.upsertLatest(m, latest);
+                    storage.insertTickIfNewer(m, latest);
+                }
+
+            } catch (Exception e) {
+                System.err.println("Startup sync failed for " + m + ": " + e.getMessage());
+            }
+        }
+    }
+
+    // ✅ API #1 every 5 minutes aligned to wall clock: 00,05,10...
+    // second=40 just to avoid API edge / second-level race
+    @CacheEvict(cacheNames = CACHE_DB_LATEST, allEntries = true)
+    @Scheduled(cron = "40 */5 * * * *", zone = "UTC")
+    public void syncApi1Every5Minutes() {
+        for (String m : metals) {
+            try {
+                MetalRatesProto.SpotPrice dto = api.fetchCurrent(m, currency, unit);
+                if (dto == null) continue;
+
+                storage.upsertLatest(m, dto);
+                storage.insertTickIfNewer(m, dto);
+
+            } catch (Exception e) {
+                System.err.println("API1 5-min sync failed for " + m + ": " + e.getMessage());
+            }
+        }
+    }
+
+    // ✅ API #2 once daily at 21:57 UTC (your requirement)
+    @Scheduled(cron = "0 58 21 * * *", zone = "UTC")
+    public void dailyIntradaySync() {
+        for (String m : metals) {
+            try {
+                MetalRatesProto.SpotPricesResponse resp = api.fetchIntraday(m, currency, unit);
+                if (resp != null && resp.hasEmbedded()) {
+                    var items = resp.getEmbedded().getItemsList();
+                    if (items != null && !items.isEmpty()) {
+                        storage.upsertIntradayTicks(m, items);
+                    }
+                    // optional:
+                    // storage.upsertLastHistoricalCandleIfPresent(m, resp);
+                }
+            } catch (Exception e) {
+                System.err.println("Daily intraday sync failed for " + m + ": " + e.getMessage());
+            }
+        }
+    }
+
+    // ✅ History sync once per day 22:01 UTC (same time as intraday)
+    @Scheduled(cron = "0 3 22 * * *", zone = "UTC")
+    public void syncDailyHistory() {
+        for (String m : metals) {
+            try {
+                MetalRatesProto.HistoricalSpotPricesResponse resp = api.fetchDailyHistory(m, currency, unit);
+                if (resp != null && resp.hasEmbedded()) {
+                    var items = resp.getEmbedded().getItemsList();
+                    if (items != null && !items.isEmpty()) {
+                        storage.upsertDailyCandles(m, items, 0); // 0 => bootstrap full if empty else incremental
+                    }
+                }
+            } catch (Exception e) {
+                System.err.println("Daily history sync failed for " + m + ": " + e.getMessage());
+            }
+        }
+    }
+
+    // ✅ keep only last N days in spot_ticks_5m
+    @Scheduled(cron = "0 5 22 * * *", zone = "UTC")
+    public void cleanupIntraday() {
+        try {
+            long deleted = storage.cleanupIntradayOlderThanDays(retentionDays);
+            System.out.println("Cleanup done, deleted rows: " + deleted);
