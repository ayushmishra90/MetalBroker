+package com.hugoserve.metalbroker.facade;
+
+import com.google.protobuf.util.JsonFormat;
+import com.hugoserve.metalbroker.domain.entity.MetalEntity;
+import com.hugoserve.metalbroker.proto.MetalRatesProto;
+import com.hugoserve.metalbroker.service.DbMetalAdminService;
+import com.hugoserve.metalbroker.utils.DbProtoMapper;
+import com.hugoserve.metalbroker.utils.ProtoJson;
+import org.springframework.http.ResponseEntity;
+import org.springframework.stereotype.Component;
+
+@Component
+public class DbMetalAdminFacade {
+
+    private final DbMetalAdminService service;
+    private final DbProtoMapper mapper;
+
+    public DbMetalAdminFacade(DbMetalAdminService service, DbProtoMapper mapper) {
+        this.service = service;
+        this.mapper = mapper;
+    }
+
+    public ResponseEntity<String> create(String json) throws Exception {
+        MetalRatesProto.MetalInfo req = parseMetalInfo(json);
+
+        if (req.getMetal() == MetalRatesProto.Metal.METAL_UNSPECIFIED) {
+            return ResponseEntity.badRequest().body("{\"error\":\"metal must be XAU/XAG/XPD/XPT\"}");
+        }
+
+        String code = req.getMetal().name();
+        MetalEntity saved = service.upsert(code, req.getName(), req.getIsActive());
+        return ResponseEntity.ok(ProtoJson.print(mapper.metalInfo(saved)));
+    }
+
+    public ResponseEntity<String> update(String code, String json) throws Exception {
+        // Parse but treat missing fields as null (so we don't accidentally set isActive=false)
+        MetalRatesProto.MetalInfo req = parseMetalInfo(json);
+
+        String nameOrNull = (req.getName() == null || req.getName().isBlank()) ? null : req.getName();
+
+        // IMPORTANT: proto boolean defaults false, so we can't know if omitted unless you change parser strategy.
+        // Best workaround: for update, parse raw JSON to check if "isActive"/"is_active" key exists.
+        // For now, simplest: require is_active always in update OR you use PATCH later.
+        Boolean isActiveOrNull = null; // safer default
+        if (json.contains("\"isActive\"") || json.contains("\"is_active\"")) {
+            isActiveOrNull = req.getIsActive();
+        }
+
+        return service.update(code, nameOrNull, isActiveOrNull)
+                .map(saved -> ResponseEntity.ok(ProtoJson.print(mapper.metalInfo(saved))))
+                .orElseGet(() -> ResponseEntity.notFound().build());
+    }
+
+    public ResponseEntity<String> deactivate(String code) {
+        return service.deactivate(code)
+                .map(saved -> ResponseEntity.ok(ProtoJson.print(mapper.metalInfo(saved))))
+                .orElseGet(() -> ResponseEntity.notFound().build());
+    }
+
+    private MetalRatesProto.MetalInfo parseMetalInfo(String json) throws Exception {
+        var b = MetalRatesProto.MetalInfo.newBuilder();
+        JsonFormat.parser().ignoringUnknownFields().merge(json, b);
+        return b.build();
+    }
+}
