+package com.hugoserve.metalbroker.service.impl;
+
+import com.hugoserve.metalbroker.domain.entity.MetalDailyHistoryEntity;
+import com.hugoserve.metalbroker.domain.entity.MetalEntity;
+import com.hugoserve.metalbroker.domain.repo.MetalDailyHistoryRepository;
+import com.hugoserve.metalbroker.domain.repo.MetalRepository;
+import com.hugoserve.metalbroker.service.DbHistoryAdminService;
+import jakarta.transaction.Transactional;
+import org.springframework.stereotype.Service;
+
+import java.math.BigDecimal;
+import java.time.LocalDate;
+import java.util.List;
+
+@Service
+public class DbHistoryAdminServiceImpl implements DbHistoryAdminService {
+
+    private final MetalRepository metalRepo;
+    private final MetalDailyHistoryRepository historyRepo;
+
+    public DbHistoryAdminServiceImpl(MetalRepository metalRepo, MetalDailyHistoryRepository historyRepo) {
+        this.metalRepo = metalRepo;
+        this.historyRepo = historyRepo;
+    }
+
+    private MetalEntity requireMetal(String metalCode) {
+        return metalRepo.findByCode(metalCode.toUpperCase())
+                .orElseThrow(() -> new IllegalArgumentException("Unknown metal code: " + metalCode));
+    }
+
+    private static BigDecimal bd(double v) { return BigDecimal.valueOf(v); }
+
+    @Override
+    @Transactional
+    public MetalDailyHistoryEntity upsertOne(String metalCode, LocalDate dayUtc,
+                                             double open, double high, double low, double close,
+                                             Double ma50OrNull, Double ma200OrNull,
+                                             String sourceOrNull) {
+
+        MetalEntity metal = requireMetal(metalCode);
+
+        MetalDailyHistoryEntity e = historyRepo.findByMetal_IdAndDayUtc(metal.getId(), dayUtc)
+                .orElseGet(MetalDailyHistoryEntity::new);
+
+        e.setMetal(metal);
+        e.setDayUtc(dayUtc);
+        e.setOpen(bd(open));
+        e.setHigh(bd(high));
+        e.setLow(bd(low));
+        e.setClose(bd(close));
+
+        if (ma50OrNull != null) e.setMa50(bd(ma50OrNull));
+        if (ma200OrNull != null) e.setMa200(bd(ma200OrNull));
+
+        if (sourceOrNull != null && !sourceOrNull.isBlank()) e.setSource(sourceOrNull);
+
+        return historyRepo.save(e);
+    }
+
+    @Override
+    @Transactional
+    public int upsertBulk(String metalCode, List<CandleInput> candles) {
+        MetalEntity metal = requireMetal(metalCode);
+
+        int affected = 0;
+        for (CandleInput it : candles) {
+            if (it.dayUtc() == null) continue;
+
+            MetalDailyHistoryEntity e = historyRepo.findByMetal_IdAndDayUtc(metal.getId(), it.dayUtc())
+                    .orElseGet(MetalDailyHistoryEntity::new);
+
+            e.setMetal(metal);
+            e.setDayUtc(it.dayUtc());
+            e.setOpen(bd(it.open()));
+            e.setHigh(bd(it.high()));
+            e.setLow(bd(it.low()));
+            e.setClose(bd(it.close()));
+            if (it.ma50() != null) e.setMa50(bd(it.ma50()));
+            if (it.ma200() != null) e.setMa200(bd(it.ma200()));
+            if (it.source() != null && !it.source().isBlank()) e.setSource(it.source());
+
+            historyRepo.save(e);
+            affected++;
+        }
+        return affected;
+    }
+
+    @Override
+    @Transactional
+    public boolean deleteOne(String metalCode, LocalDate dayUtc) {
+        MetalEntity metal = requireMetal(metalCode);
+        var row = historyRepo.findByMetal_IdAndDayUtc(metal.getId(), dayUtc).orElse(null);
+        if (row == null) return false;
+        historyRepo.delete(row);
+        return true;
+    }
+
+    @Override
+    @Transactional
+    public int deleteRange(String metalCode, LocalDate fromDay, LocalDate toDay) {
+        MetalEntity metal = requireMetal(metalCode);
+        var rows = historyRepo.findByMetal_IdAndDayUtcBetweenOrderByDayUtcAsc(metal.getId(), fromDay, toDay);
+        historyRepo.deleteAll(rows);
+        return rows.size();
+    }
+}
