+        }
+
+        var b = MetalRatesProto.Tick5mList.newBuilder()
+                .setMetal(mapper.toMetalEnum(metal.toUpperCase()));
+        items.forEach(e -> b.addItems(mapper.tick5m(e)));
+
+        return ResponseEntity.ok(ProtoJson.print(b.build()));
+    }
+
+    public ResponseEntity<String> history(String metal, LocalDate fromDay, LocalDate toDay) {
+        var rows = service.dailyHistory(metal, fromDay, toDay);
+
+        var b = MetalRatesProto.DailyHistoryList.newBuilder()
+                .setMetal(mapper.toMetalEnum(metal.toUpperCase()));
+        rows.forEach(r -> b.addItems(mapper.dailyHistoryCandle(r)));
+
+        return ResponseEntity.ok(ProtoJson.print(b.build()));
+    }
+
+    private void validatePage(int page, int size) {
+        if (page < 0) throw new IllegalArgumentException("page must be >= 0");
+        if (size < 1 || size > 1000) {
+            throw new IllegalArgumentException("size must be between 1 and 1000");
+        }
+    }
+
+    private Sort sort(String field, String dir) {
+        if (field == null || field.isBlank()) return Sort.unsorted();
+        return "desc".equalsIgnoreCase(dir)
+                ? Sort.by(field).descending()
+                : Sort.by(field).ascending();
+    }
+
+    public ResponseEntity<String> intradayPage(String metal,
+                                          Instant from,
+                                          Instant to,
+                                          int page,
+                                          int size,
+                                          String sort,
+                                          String dir) {
+
+        if (from.isAfter(to)) {
+            return ResponseEntity.badRequest().body("from must be <= to");
+        }
+
+        validatePage(page, size);
+
+        PageRequest pr = PageRequest.of(page, size, sort(sort, dir));
+        Page<?> p = service.intradayTicksPage(metal, from, to, pr);
+
+        var b = MetalRatesProto.Tick5mPage.newBuilder()
+                .setMetal(mapper.toMetalEnum(metal.toUpperCase()))
+                .setPage(
+                        MetalRatesProto.PageInfo.newBuilder()
+                                .setPage(p.getNumber())
+                                .setSize(p.getSize())
+                                .setTotalElements(p.getTotalElements())
+                                .setTotalPages(p.getTotalPages())
+                                .build()
+                );
+
+
+        p.getContent().forEach(e ->
+                b.addItems(mapper.tick5m((com.hugoserve.metalbroker.domain.entity.SpotTick5mEntity) e))
+        );
+
+        return ResponseEntity.ok(ProtoJson.print(b.build()));
+
+    }
+
+
+    public ResponseEntity<String> historyPage(String metal,
+                                         LocalDate fromDay,
+                                         LocalDate toDay,
+                                         int page,
+                                         int size,
+                                         String sort,
+                                         String dir) {
+
+        if (fromDay.isAfter(toDay)) {
+            return ResponseEntity.badRequest().body("fromDay must be <= toDay");
+        }
+
+        validatePage(page, size);
+
+        PageRequest pr = PageRequest.of(page, size, sort(sort, dir));
+        Page<?> p = service.dailyHistoryPage(metal, fromDay, toDay, pr);
+
+        var b = MetalRatesProto.DailyHistoryPage.newBuilder()
+                .setMetal(mapper.toMetalEnum(metal.toUpperCase()))
+                .setPage(
+                        MetalRatesProto.PageInfo.newBuilder()
+                                .setPage(p.getNumber())
+                                .setSize(p.getSize())
+                                .setTotalElements(p.getTotalElements())
+                                .setTotalPages(p.getTotalPages())
+                                .build()
+                );
+
+
+        p.getContent().forEach(r ->
+                b.addItems(mapper.dailyHistoryCandle(
+                        (com.hugoserve.metalbroker.domain.entity.MetalDailyHistoryEntity) r))
+        );
+
+        return ResponseEntity.ok(ProtoJson.print(b.build()));
+
+    }
+
+}
