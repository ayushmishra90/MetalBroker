+package com.hugoserve.metalbroker.facade;
+
+import com.hugoserve.metalbroker.domain.entity.MetalDailyHistoryEntity;
+import com.hugoserve.metalbroker.proto.MetalRatesProto;
+import com.hugoserve.metalbroker.service.DbHistoryAdminService;
+import com.hugoserve.metalbroker.utils.DbProtoMapper;
+import com.hugoserve.metalbroker.utils.ProtoJson;
+import com.hugoserve.metalbroker.utils.ProtoJsonParser;
+import org.springframework.http.HttpStatus;
+import org.springframework.http.ResponseEntity;
+import org.springframework.stereotype.Component;
+
+import java.time.LocalDate;
+import java.util.List;
+
+@Component
+public class DbHistoryAdminFacade {
+
+    private final DbHistoryAdminService service;
+    private final DbProtoMapper mapper;
+
+    public DbHistoryAdminFacade(DbHistoryAdminService service, DbProtoMapper mapper) {
+        this.service = service;
+        this.mapper = mapper;
+    }
+
+    public ResponseEntity<String> upsertOne(String json) {
+        MetalRatesProto.DailyHistoryCandle req;
+        try {
+            req = ProtoJsonParser.parse(json, MetalRatesProto.DailyHistoryCandle.newBuilder()).build();
+        } catch (RuntimeException ex) {
+            return ResponseEntity.badRequest().body("{\"error\":\"invalid proto json\"}");
+        }
+
+        if (req.getMetal() == MetalRatesProto.Metal.METAL_UNSPECIFIED) {
+            return ResponseEntity.badRequest().body("{\"error\":\"metal must be XAU/XAG/XPD/XPT\"}");
+        }
+        if (req.getDayUtc().isEmpty()) {
+            return ResponseEntity.badRequest().body("{\"error\":\"dayUtc is required\"}");
+        }
+
+        String metalCode = req.getMetal().name();
+        LocalDate day = LocalDate.parse(req.getDayUtc());
+
+        Double ma50 = req.hasMa50() ? req.getMa50() : null;
+        Double ma200 = req.hasMa200() ? req.getMa200() : null;
+
+        MetalDailyHistoryEntity saved = service.upsertOne(
+                metalCode, day,
+                req.getOpen(), req.getHigh(), req.getLow(), req.getClose(),
+                ma50, ma200,
+                req.getSource().isEmpty() ? null : req.getSource()
+        );
+
+        return ResponseEntity.ok(ProtoJson.print(mapper.dailyHistoryCandle(saved)));
+    }
+
+    public ResponseEntity<String> upsertBulk(String json) {
+        MetalRatesProto.DailyHistoryList req;
+        try {
+            req = ProtoJsonParser.parse(json, MetalRatesProto.DailyHistoryList.newBuilder()).build();
+        } catch (RuntimeException ex) {
+            return ResponseEntity.badRequest().body("{\"error\":\"invalid proto json\"}");
+        }
+
+        if (req.getMetal() == MetalRatesProto.Metal.METAL_UNSPECIFIED) {
+            return ResponseEntity.badRequest().body("{\"error\":\"metal required in DailyHistoryList\"}");
+        }
+
+        String metalCode = req.getMetal().name();
+
+        List<DbHistoryAdminService.CandleInput> candles = req.getItemsList().stream()
+                .filter(it -> !it.getDayUtc().isEmpty())
+                .map(it -> new DbHistoryAdminService.CandleInput(
+                        LocalDate.parse(it.getDayUtc()),
+                        it.getOpen(), it.getHigh(), it.getLow(), it.getClose(),
+                        it.hasMa50() ? it.getMa50() : null,
+                        it.hasMa200() ? it.getMa200() : null,
+                        it.getSource()
+                ))
+                .toList();
+
+        int affected = service.upsertBulk(metalCode, candles);
+
+        var resp = MetalRatesProto.AdminWriteResult.newBuilder()
+                .setOk(true)
+                .setMessage("bulk upsert completed")
+                .setAffected(affected)
+                .build();
+
+        return ResponseEntity.ok(ProtoJson.print(resp));
+    }
+
+    public ResponseEntity<String> deleteOne(String metal, LocalDate day) {
+        boolean ok = service.deleteOne(metal, day);
+
+        if (!ok) {
+            var errorResp = MetalRatesProto.AdminWriteResult.newBuilder()
+                    .setOk(false)
+                    .setMessage("not found any entry of " + day + " of the " + metal)
+                    .build();
+
+            // Returns 404 status with the JSON error message
+            return ResponseEntity.ok(ProtoJson.print(errorResp));
+        }
+
+        var resp = MetalRatesProto.AdminWriteResult.newBuilder()
+                .setOk(true)
+                .setMessage("deleted day=" + day)
+                .build();
+
+        return ResponseEntity.ok(ProtoJson.print(resp));
+    }
+
+    public ResponseEntity<String> deleteRange(String metal, LocalDate fromDay, LocalDate toDay) {
+        int deleted = service.deleteRange(metal, fromDay, toDay);
+
+        var resp = MetalRatesProto.AdminWriteResult.newBuilder()
+                .setOk(true)
+                .setMessage("deleted=" + deleted)
+                .setAffected(deleted)
+                .build();
+
+        return ResponseEntity.ok(ProtoJson.print(resp));
+    }
+}
