+
+    public DbRatesReadFacade(DbRatesReadService service, DbProtoMapper mapper) {
+        this.service = service;
+        this.mapper = mapper;
+    }
+
+    public ResponseEntity<String> latest(String metal) {
+        return service.latestByMetalCode(metal)
+                .map(e -> ResponseEntity.ok(ProtoJson.print(mapper.latestSnapshot(e))))
+                .orElseGet(() -> ResponseEntity.notFound().build());
+    }
+
+    public ResponseEntity<String> intraday(String metal, Instant from, Instant to) {
+        var items = service.intradayTicks(metal, from, to);
+        if (items.isEmpty()) {
+            // IMPORTANT: if metal code invalid, service returns empty.
+            // If you want strict 404 for unknown metal, we can change service to expose "metal exists" check.
