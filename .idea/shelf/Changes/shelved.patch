+        var m = metalRepo.findByName(metal).orElse(null);
+        if (m == null) return ResponseEntity.notFound().build();
+        return ResponseEntity.ok(ticksRepo.findByMetal_IdAndTsUtcBetweenOrderByTsUtcAsc(m.getId(), from, to));
+    }
