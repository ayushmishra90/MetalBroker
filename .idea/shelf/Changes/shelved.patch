+  XAG = 1;
+  XAU = 2;
+  XPD = 3;
+  XPT = 4;
+}
+
+enum Currency {
+  CURRENCY_UNSPECIFIED = 0;
+  PKR = 1;
+  INR = 2;
+  USD = 3;
+  EUR = 4;
+  JPY = 5;
+  AUD = 6;
+}
+
+// --- NEW ENUMS FOR AUTH & TRADING ---
+
+enum UserRole {
+  ROLE_UNSPECIFIED = 0;
+  USER = 1;
+  ADMIN = 2;
+}
+
+enum TradeType {
+  TRADE_TYPE_UNSPECIFIED = 0;
+  BUY = 1;
+  SELL = 2;
+}
+
+// --- AUTHENTICATION MESSAGES ---
+
+message LoginRequest {
+  string email = 1;
+  string password = 2;
+}
+
+message RefreshTokenRequest {
+  string refresh_token = 1;
+}
+
+message RegisterRequest {
+  string email = 1;
+  string password = 2;
+  string first_name = 3;
+  string last_name = 4;
+}
+
+message TokenPair {
+  string access_token = 1;
+  string refresh_token = 2;
+  google.protobuf.Timestamp access_expires_at = 3;
+  google.protobuf.Timestamp refresh_expires_at = 4;
+}
+
+message AuthResponse {
+  bool success = 1;
+  string message = 2;
+  UserRole role = 3;
+  TokenPair tokens = 4; // Only populated on success
+}
+
+// --- WALLET & TRADING MESSAGES (Future Proofing) ---
+
+message WalletBalance {
+  Metal metal = 1;        // Using your existing Metal enum
+  double balance = 2;     // Quantity
+  double valuation = 3;   // Current Value in base currency
+}
+
+message WalletSummary {
+  string wallet_id = 1;
+  repeated WalletBalance balances = 2;
+  double total_equity = 3;
+}
+
+message TradeRequest {
+  TradeType type = 1;
+  Metal metal = 2;
+  double quantity = 3;
+  double locked_price = 4;
+}
+
+message TradeResponse {
+  bool success = 1;
+  string message = 2;
+  string trade_id = 3;
+  double executed_price = 4;
+  double total_cost = 5;
+  WalletSummary new_wallet_state = 6;
+}
+
+// --- EXISTING RATE MESSAGES (UNCHANGED) ---
+
+message SpotPrice {
+  // Supports "2026-01-15T22:15:00+00:00"
+  google.protobuf.Timestamp date = 1;
+  WeightUnit weight_unit = 2;
+  double ask = 3;
+  double mid = 4;
+  double bid = 5;
+  double value = 6;
+  double performance = 7;
+}
+
+message HistoricalSpotPricesResponse {
+  Metal metal = 1;
+  Currency currency = 2;
+  WeightUnit weight_unit = 3;
+  HistoricalEmbeddedItems embedded = 4 [json_name = "_embedded"];
+}
+
+message SpotPricesResponse {
+  Metal metal = 1;
+  Currency currency = 2;
+  WeightUnit weight_unit = 3;
+  EmbeddedItems embedded = 4 [json_name = "_embedded"];
+}
+
+message EmbeddedItems {
+  repeated SpotPrice items = 1;
+  int32 markets_closed = 2;
+  SpotPriceItem last_historical_spot_price = 3;
+}
+
+message HistoricalEmbeddedItems {
+  repeated SpotPriceItem items = 1;
+  Performances performances = 2;
+}
+
+message SpotPriceItem {
+  string date = 1;
+  WeightUnit weight_unit = 2;
+
+  double close = 3;
+  double high = 4;
+  double low = 5;
+  double open = 6;
+
+  optional double ma50 = 7;
+  optional double ma200 = 8;
+}
+
+message Performances {
+  double D5  = 1 [json_name = "5D"];
+  double M1  = 2 [json_name = "1M"];
+  double YTD = 3 [json_name = "YTD"];
+  double Y1  = 4 [json_name = "1Y"];
+  double Y5  = 5 [json_name = "5Y"];
+  double Y10 = 6 [json_name = "10Y"];
+  double MAX = 7 [json_name = "MAX"];
+}
+
+message AdminWriteResult {
+  bool ok = 1;
+  string message = 2;
+  int64 affected = 3;
+}
+message MetalInfo {
+  int64 id = 1;
