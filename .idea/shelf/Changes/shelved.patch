+CREATE TABLE IF NOT EXISTS metals (
+                        id BIGINT PRIMARY KEY AUTO_INCREMENT,
+                        code VARCHAR(8) NOT NULL UNIQUE,     -- XAU, XAG, XPT, XPD
+                        name VARCHAR(64) NOT NULL,
+                        is_active BOOLEAN NOT NULL DEFAULT TRUE
+);
+
+-- latest snapshot (API #1)
+CREATE TABLE IF NOT EXISTS metal_latest (
+                              metal_id BIGINT PRIMARY KEY,
+                              feed_ts_utc DATETIME(3) NOT NULL,         -- from API date
+                              captured_at_utc DATETIME(3) NOT NULL,     -- when we fetched
+                              ask DECIMAL(20,6) NULL,
+                              mid DECIMAL(20,6) NULL,
+                              bid DECIMAL(20,6) NULL,
+                              value DECIMAL(20,6) NULL,
+                              performance DECIMAL(20,6) NULL,
+                              source VARCHAR(64) NOT NULL DEFAULT 'goldbroker',
+                              CONSTRAINT fk_latest_metal FOREIGN KEY (metal_id) REFERENCES metals(id)
+);
+
+-- intraday 5-min ticks (API #2 _embedded.items)
+CREATE TABLE IF NOT EXISTS spot_ticks_5m (
+                               id BIGINT PRIMARY KEY AUTO_INCREMENT,
+                               metal_id BIGINT NOT NULL,
+                               ts_utc DATETIME(3) NOT NULL,
+                               ask DECIMAL(20,6) NULL,
+                               mid DECIMAL(20,6) NULL,
+                               bid DECIMAL(20,6) NULL,
+                               value DECIMAL(20,6) NULL,
+                               performance DECIMAL(20,6) NULL,
+                               source VARCHAR(64) NOT NULL DEFAULT 'goldbroker',
+                               created_at DATETIME(3) NOT NULL DEFAULT CURRENT_TIMESTAMP(3),
+
+                               CONSTRAINT fk_tick_metal FOREIGN KEY (metal_id) REFERENCES metals(id),
+                               CONSTRAINT uq_tick UNIQUE (metal_id, ts_utc)
+);
+
+CREATE INDEX  idx_tick_metal_ts ON spot_ticks_5m(metal_id, ts_utc DESC);
+
+-- daily candles (API #3 _embedded.items; also API #2 last_historical_spot_price)
+CREATE TABLE IF NOT EXISTS metal_daily_history (
+                               id BIGINT PRIMARY KEY AUTO_INCREMENT,
+                               metal_id BIGINT NOT NULL,
+                               day_utc DATE NOT NULL,
+                               open DECIMAL(20,6) NOT NULL,
+                               high DECIMAL(20,6) NOT NULL,
+                               low DECIMAL(20,6) NOT NULL,
+                               close DECIMAL(20,6) NOT NULL,
+                               ma50 DECIMAL(20,6) NULL,
+                               ma200 DECIMAL(20,6) NULL,
+                               source VARCHAR(64) NOT NULL DEFAULT 'goldbroker',
+                               created_at DATETIME(3) NOT NULL DEFAULT CURRENT_TIMESTAMP(3),
+
+                               CONSTRAINT fk_candle_metal FOREIGN KEY (metal_id) REFERENCES metals(id),
+                               CONSTRAINT uq_candle UNIQUE (metal_id, day_utc)
+);
+
+CREATE INDEX idx_history_metal ON metal_daily_history(metal_id, day_utc DESC);
