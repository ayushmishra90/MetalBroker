+package com.hugoserve.metalbroker.service.impl;
+
+import com.hugoserve.metalbroker.domain.entity.*;
+import com.hugoserve.metalbroker.domain.repo.*;
+import com.hugoserve.metalbroker.proto.MetalRatesProto;
+import com.hugoserve.metalbroker.service.RateStorageService;
+import jakarta.transaction.Transactional;
+import org.springframework.stereotype.Service;
+
+import java.math.BigDecimal;
+import java.time.*;
+import java.util.Comparator;
+import java.util.List;
+
+@Service
+public class RateStorageServiceImpl implements RateStorageService {
+
+    private final MetalRepository metalRepo;
+    private final MetalLatestRepository latestRepo;
+    private final SpotTick5mRepository tickRepo;
+    private final MetalDailyHistoryRepository candleRepo;
+
+    public RateStorageServiceImpl(MetalRepository metalRepo,
+                                  MetalLatestRepository latestRepo,
+                                  SpotTick5mRepository tickRepo,
+                                  MetalDailyHistoryRepository candleRepo) {
+        this.metalRepo = metalRepo;
+        this.latestRepo = latestRepo;
+        this.tickRepo = tickRepo;
+        this.candleRepo = candleRepo;
+    }
+
+    private MetalEntity requireMetal(String codeOrName) {
+        // BEST: store metals.code = XAU/XAG/... and always use findByCode.
+        // If scheduler still passes "gold" etc, keep findByName.
+        return metalRepo.findByCode(codeOrName).or(() -> metalRepo.findByName(codeOrName))
+                .orElseThrow(() -> new IllegalArgumentException("Unknown metal: " + codeOrName));
+    }
+
+    private Instant toInstant(MetalRatesProto.SpotPrice p) {
+        return Instant.ofEpochSecond(p.getDate().getSeconds(), p.getDate().getNanos());
+    }
+
+    private BigDecimal bd(double v) { return BigDecimal.valueOf(v); }
+
+    private BigDecimal opt(boolean has, double v) { return has ? BigDecimal.valueOf(v) : null; }
+
+    @Override
+    @Transactional
+    public void upsertLatest(String metalCode, MetalRatesProto.SpotPrice dto) {
+        if (dto == null) return;
+
+        MetalEntity metal = requireMetal(metalCode);
+
+        MetalLatestEntity latest = latestRepo.findById(metal.getId()).orElseGet(MetalLatestEntity::new);
+        latest.setMetal(metal);
+
+        latest.setFeedTsUtc(toInstant(dto));
+        latest.setCapturedAtUtc(Instant.now());
+
+        latest.setAsk(bd(dto.getAsk()));
+        latest.setMid(bd(dto.getMid()));
+        latest.setBid(bd(dto.getBid()));
+        latest.setValue(bd(dto.getValue()));
+        latest.setPerformance(bd(dto.getPerformance()));
+
+        latestRepo.save(latest);
+    }
+
+    @Override
+    @Transactional
+    public void insertTickIfNewer(String metalCode, MetalRatesProto.SpotPrice dto) {
+        if (dto == null) return;
+
+        MetalEntity metal = requireMetal(metalCode);
+        Instant incomingTs = toInstant(dto);
+
+        Instant lastTs = tickRepo.findFirstByMetal_IdOrderByTsUtcDesc(metal.getId())
+                .map(SpotTick5mEntity::getTsUtc)
+                .orElse(Instant.EPOCH);
+
+        if (!incomingTs.isAfter(lastTs)) return;
+
+        SpotTick5mEntity e = new SpotTick5mEntity();
+        e.setMetal(metal);
+        e.setTsUtc(incomingTs);
+
+        e.setAsk(bd(dto.getAsk()));
+        e.setMid(bd(dto.getMid()));
+        e.setBid(bd(dto.getBid()));
+        e.setValue(bd(dto.getValue()));
+        e.setPerformance(bd(dto.getPerformance()));
+
+        try { tickRepo.save(e); } catch (Exception ignored) {}
+    }
+
+    @Override
+    @Transactional
+    public void upsertIntradayTicks(String metalCode, List<MetalRatesProto.SpotPrice> items) {
+        if (items == null || items.isEmpty()) return;
+
+        MetalEntity metal = requireMetal(metalCode);
+
+        Instant lastTs = tickRepo.findFirstByMetal_IdOrderByTsUtcDesc(metal.getId())
+                .map(SpotTick5mEntity::getTsUtc)
+                .orElse(Instant.EPOCH);
+
+        items.stream()
+                .sorted(Comparator.comparing(this::toInstant))
+                .filter(p -> toInstant(p).isAfter(lastTs))
+                .forEach(p -> {
+                    SpotTick5mEntity e = new SpotTick5mEntity();
+                    e.setMetal(metal);
+                    e.setTsUtc(toInstant(p));
+                    e.setAsk(bd(p.getAsk()));
+                    e.setMid(bd(p.getMid()));
+                    e.setBid(bd(p.getBid()));
+                    e.setValue(bd(p.getValue()));
+                    e.setPerformance(bd(p.getPerformance()));
+                    try { tickRepo.save(e); } catch (Exception ignored) {}
+                });
+    }
+
+    @Override
+    @Transactional
+    public void upsertLastHistoricalCandleIfPresent(String metalCode, MetalRatesProto.SpotPricesResponse response) {
+        if (response == null || !response.hasEmbedded() || !response.getEmbedded().hasLastHistoricalSpotPrice()) return;
+
+        MetalEntity metal = requireMetal(metalCode);
+        MetalRatesProto.SpotPriceItem d = response.getEmbedded().getLastHistoricalSpotPrice();
+
+        LocalDate day = LocalDate.parse(d.getDate());
+
+        MetalDailyHistoryEntity candle = candleRepo.findByMetal_IdAndDayUtc(metal.getId(), day)
+                .orElseGet(MetalDailyHistoryEntity::new);
+
+        candle.setMetal(metal);
+        candle.setDayUtc(day);
+
+        candle.setOpen(bd(d.getOpen()));
+        candle.setHigh(bd(d.getHigh()));
+        candle.setLow(bd(d.getLow()));
+        candle.setClose(bd(d.getClose()));
+        candle.setMa50(opt(d.hasMa50(), d.getMa50()));
+        candle.setMa200(opt(d.hasMa200(), d.getMa200()));
+
+        candleRepo.save(candle);
+    }
+
+    @Override
+    @Transactional
+    public void upsertDailyCandles(String metalCode, List<MetalRatesProto.SpotPriceItem> items, int lastNDaysOnly) {
+        if (items == null || items.isEmpty()) return;
+
+        MetalEntity metal = requireMetal(metalCode);
+
+        LocalDate maxDayInDb = candleRepo.findMaxDayUtcByMetalId(metal.getId());
+
+        // If DB empty -> bootstrap FULL history (ignore lastNDaysOnly)
+        List<MetalRatesProto.SpotPriceItem> list = items;
+        if (maxDayInDb != null && lastNDaysOnly > 0 && items.size() > lastNDaysOnly) {
+            list = items.subList(items.size() - lastNDaysOnly, items.size());
+        }
+
+        for (var i : list) {
+            LocalDate day = LocalDate.parse(i.getDate());
+
+            boolean shouldWrite = (maxDayInDb == null) || day.isAfter(maxDayInDb) || day.isEqual(maxDayInDb);
+            if (!shouldWrite) continue;
+
+            MetalDailyHistoryEntity candle = candleRepo.findByMetal_IdAndDayUtc(metal.getId(), day)
+                    .orElseGet(MetalDailyHistoryEntity::new);
+
+            candle.setMetal(metal);
+            candle.setDayUtc(day);
+            candle.setOpen(bd(i.getOpen()));
+            candle.setHigh(bd(i.getHigh()));
+            candle.setLow(bd(i.getLow()));
+            candle.setClose(bd(i.getClose()));
+            candle.setMa50(opt(i.hasMa50(), i.getMa50()));
+            candle.setMa200(opt(i.hasMa200(), i.getMa200()));
+
+            try { candleRepo.save(candle); } catch (Exception ignored) {}
+        }
+    }
+
+    @Override
+    @Transactional
+    public long cleanupIntradayOlderThanDays(int days) {
+        Instant cutoff = Instant.now().minus(Duration.ofDays(days));
+        return tickRepo.deleteByTsUtcBefore(cutoff);
+    }
+}
