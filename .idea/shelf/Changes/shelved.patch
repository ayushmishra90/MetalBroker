+
+        Instant old = Instant.now().minusSeconds(60L * 60 * 24 * 10); // 10 days ago
+        Instant fresh = Instant.now();
+
+        SpotTick5mEntity a = new SpotTick5mEntity();
+        a.setMetal(m); a.setTsUtc(old); a.setAsk(new BigDecimal("1.0"));
+        tickRepo.save(a);
+
+        SpotTick5mEntity b = new SpotTick5mEntity();
