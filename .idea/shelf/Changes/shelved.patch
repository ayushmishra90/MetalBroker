+package com.hugoserve.metalbroker.facade;
+
+import com.hugoserve.metalbroker.domain.entity.SpotTick5mEntity;
+import com.hugoserve.metalbroker.proto.MetalRatesProto;
+import com.hugoserve.metalbroker.service.DbTicksAdminService;
+import com.hugoserve.metalbroker.utils.DbProtoMapper;
+import com.hugoserve.metalbroker.utils.ProtoJson;
+import com.hugoserve.metalbroker.utils.ProtoJsonParser;
+import org.springframework.http.ResponseEntity;
+import org.springframework.stereotype.Component;
+
+import java.time.Instant;
+import java.util.Comparator;
+
+@Component
+public class DbTicksAdminFacade {
+
+    private final DbTicksAdminService service;
+    private final DbProtoMapper mapper;
+
+    public DbTicksAdminFacade(DbTicksAdminService service, DbProtoMapper mapper) {
+        this.service = service;
+        this.mapper = mapper;
+    }
+
+    private Instant toInstant(MetalRatesProto.Tick5m p) {
+        return Instant.ofEpochSecond(p.getTsUtc().getSeconds(), p.getTsUtc().getNanos());
+    }
+
+    public ResponseEntity<String> upsertOne(String json) {
+        MetalRatesProto.Tick5m req;
+        try {
+            req = ProtoJsonParser.parse(json, MetalRatesProto.Tick5m.newBuilder()).build();
+        } catch (RuntimeException ex) {
+            return ResponseEntity.badRequest().body("{\"error\":\"invalid proto json\"}");
+        }
+
+        if (req.getMetal() == MetalRatesProto.Metal.METAL_UNSPECIFIED) {
+            return ResponseEntity.badRequest().body("{\"error\":\"metal must be XAU/XAG/XPD/XPT\"}");
+        }
+        if (!req.hasTsUtc()) {
+            return ResponseEntity.badRequest().body("{\"error\":\"tsUtc is required\"}");
+        }
+
+        String metalCode = req.getMetal().name();
+        Instant ts = toInstant(req);
+
+        try {
+            SpotTick5mEntity saved = service.insertTick(
+                    metalCode, ts,
+                    req.getAsk(), req.getMid(), req.getBid(),
+                    req.getValue(), req.getPerformance(),
+                    req.getSource().isEmpty() ? null : req.getSource()
+            );
+            return ResponseEntity.ok(ProtoJson.print(mapper.tick5m(saved)));
+        } catch (Exception dupOrOther) {
+            // keep your "idempotent" behavior
+            return ResponseEntity.ok(ProtoJson.print(req));
+        }
+    }
+
+    public ResponseEntity<String> upsertBulk(String json) {
+        MetalRatesProto.Tick5mList req;
+        try {
+            req = ProtoJsonParser.parse(json, MetalRatesProto.Tick5mList.newBuilder()).build();
+        } catch (RuntimeException ex) {
+            return ResponseEntity.badRequest().body("{\"error\":\"invalid proto json\"}");
+        }
+
+        if (req.getMetal() == MetalRatesProto.Metal.METAL_UNSPECIFIED) {
+            return ResponseEntity.badRequest().body("{\"error\":\"metal required in Tick5mList\"}");
+        }
+
+        String metalCode = req.getMetal().name();
+
+        var ticks = req.getItemsList().stream()
+                .filter(MetalRatesProto.Tick5m::hasTsUtc)
+                .sorted(Comparator.comparing(this::toInstant))
+                .map(it -> new DbTicksAdminService.TickInput(
+                        toInstant(it),
+                        it.getAsk(), it.getMid(), it.getBid(),
+                        it.getValue(), it.getPerformance(),
+                        it.getSource()
+                ))
+                .toList();
+
+        int inserted = service.insertTicksBulk(metalCode, ticks);
+
+        var resp = MetalRatesProto.AdminWriteResult.newBuilder()
+                .setOk(true)
+                .setMessage("bulk upsert completed (duplicates ignored)")
+                .setAffected(inserted)
+                .build();
+
+        return ResponseEntity.ok(ProtoJson.print(resp));
+    }
+
+    public ResponseEntity<String> deleteById(Long id) {
+        boolean ok = service.deleteById(id);
+
+        if (!ok) return ResponseEntity.notFound().build();
+
+        var resp = MetalRatesProto.AdminWriteResult.newBuilder()
+                .setOk(true)
+                .setMessage("deleted id=" + id)
+                .build();
+
+        return ResponseEntity.ok(ProtoJson.print(resp));
+    }
+
+    public ResponseEntity<String> deleteRange(String metal, Instant from, Instant to) {
+        int deleted = service.deleteRange(metal, from, to);
+
+        var resp = MetalRatesProto.AdminWriteResult.newBuilder()
+                .setOk(true)
+                .setMessage("deleted=" + deleted)
+                .build();
+
+        return ResponseEntity.ok(ProtoJson.print(resp));
+    }
+}
