+    }
+
+    @GetMapping(value = "/historical/debug", produces = "application/json")
+    public String historicaldebug(
+            @RequestParam Metal metal,
+            @RequestParam Currency currency,
+            @RequestParam(name = "weight_unit") WeightUnit weightUnit,
+            @RequestParam(required = false) Integer page,
+            @RequestParam(required = false) Integer limit
+    ) throws InvalidProtocolBufferException {
+        var msg = rateService.getHistoricalRates(metal, currency, weightUnit, page, limit);
+
+        return JsonFormat.printer()
+                .includingDefaultValueFields()
+                .preservingProtoFieldNames()
+                .print(msg);
+    }
+
+
+
+    @GetMapping("/latest")
+    public ResponseEntity<?> latest(@RequestParam String metal) {
+//        var m = metalRepo.findByCode(metal).orElse(null);
+        var m = metalRepo.findByName(metal).orElse(null);
+        if (m == null) return ResponseEntity.notFound().build();
+        return latestRepo.findById(m.getId())
+                .<ResponseEntity<?>>map(ResponseEntity::ok)
+                .orElseGet(() -> ResponseEntity.notFound().build());
+    }
