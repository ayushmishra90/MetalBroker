+  google.protobuf.Timestamp captured_at_utc = 3;
+
+  double ask = 4;
+  double mid = 5;
+  double bid = 6;
+  double value = 7;
+  double performance = 8;
+  string source = 9;
+}
+
+message Tick5m {
+  Metal metal = 1;
+  google.protobuf.Timestamp ts_utc = 2;
+  double ask = 3;
+  double mid = 4;
+  double bid = 5;
+  double value = 6;
+  double performance = 7;
+  string source = 8;
+}
+
+message Tick5mList {
+  Metal metal = 1;
+  repeated Tick5m items = 2;
+}
+
+message DailyHistoryCandle {
+  Metal metal = 1;
+  string day_utc = 2;   // "yyyy-MM-dd" (easy, stable)
+
+  double open = 3;
+  double high = 4;
+  double low = 5;
+  double close = 6;
+
+  optional double ma50 = 7;
+  optional double ma200 = 8;
+  string source = 9;
+}
+
+message DailyHistoryList {
+  Metal metal = 1;
+  repeated DailyHistoryCandle items = 2;
+}
+
+
+message PageInfo {
+  int32 page = 1;           // current page (0-based)
+  int32 size = 2;           // page size
+  int64 total_elements = 3; // total rows
+  int32 total_pages = 4;    // total pages
+}
+
+message Tick5mPage {
+  Metal metal = 1;
+  repeated Tick5m items = 2;
+  PageInfo page = 3;
+}
+
+message DailyHistoryPage {
+  Metal metal = 1;
+  repeated DailyHistoryCandle items = 2;
+  PageInfo page = 3;
+}
