+package com.hugoserve.metalbroker.service.impl;
+
+import com.hugoserve.metalbroker.domain.entity.MetalEntity;
+import com.hugoserve.metalbroker.domain.entity.SpotTick5mEntity;
+import com.hugoserve.metalbroker.domain.repo.MetalRepository;
+import com.hugoserve.metalbroker.domain.repo.SpotTick5mRepository;
+import com.hugoserve.metalbroker.service.DbTicksAdminService;
+import jakarta.transaction.Transactional;
+import org.springframework.stereotype.Service;
+
+import java.math.BigDecimal;
+import java.time.Instant;
+import java.util.List;
+
+@Service
+public class DbTicksAdminServiceImpl implements DbTicksAdminService {
+
+    private final MetalRepository metalRepo;
+    private final SpotTick5mRepository tickRepo;
+
+    public DbTicksAdminServiceImpl(MetalRepository metalRepo, SpotTick5mRepository tickRepo) {
+        this.metalRepo = metalRepo;
+        this.tickRepo = tickRepo;
+    }
+
+    private MetalEntity requireMetal(String metalCode) {
+        return metalRepo.findByCode(metalCode.toUpperCase())
+                .orElseThrow(() -> new IllegalArgumentException("Unknown metal code: " + metalCode));
+    }
+
+    private static BigDecimal bd(double v) { return BigDecimal.valueOf(v); }
+
+    @Override
+    @Transactional
+    public SpotTick5mEntity insertTick(String metalCode, Instant tsUtc,
+                                       double ask, double mid, double bid,
+                                       double value, double performance,
+                                       String sourceOrNull) {
+
+        MetalEntity metal = requireMetal(metalCode);
+
+        SpotTick5mEntity e = new SpotTick5mEntity();
+        e.setMetal(metal);
+        e.setTsUtc(tsUtc);
+        e.setAsk(bd(ask));
+        e.setMid(bd(mid));
+        e.setBid(bd(bid));
+        e.setValue(bd(value));
+        e.setPerformance(bd(performance));
+        if (sourceOrNull != null && !sourceOrNull.isBlank()) e.setSource(sourceOrNull);
+
+        return tickRepo.save(e); // may throw duplicate constraint
+    }
+
+    @Override
+    @Transactional
+    public int insertTicksBulk(String metalCode, List<TickInput> ticks) {
+        MetalEntity metal = requireMetal(metalCode);
+
+        int inserted = 0;
+        for (TickInput it : ticks) {
+            if (it.tsUtc() == null) continue;
+
+            SpotTick5mEntity e = new SpotTick5mEntity();
+            e.setMetal(metal);
+            e.setTsUtc(it.tsUtc());
+            e.setAsk(bd(it.ask()));
+            e.setMid(bd(it.mid()));
+            e.setBid(bd(it.bid()));
+            e.setValue(bd(it.value()));
+            e.setPerformance(bd(it.performance()));
+            if (it.source() != null && !it.source().isBlank()) e.setSource(it.source());
+
+            try {
+                tickRepo.save(e);
+                inserted++;
+            } catch (Exception ignored) {
+                // duplicates ignored
+            }
+        }
+        return inserted;
+    }
+
+    @Override
+    @Transactional
+    public boolean deleteById(long id) {
+        if (!tickRepo.existsById(id)) return false;
+        tickRepo.deleteById(id);
+        return true;
+    }
+
+    @Override
+    @Transactional
+    public int deleteRange(String metalCode, Instant from, Instant to) {
+        MetalEntity metal = requireMetal(metalCode);
+        return tickRepo.deleteByMetalAndTsRange(metal.getId(), from, to);
+    }
+}
