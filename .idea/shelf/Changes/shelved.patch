+package com.hugoserve.metalbroker.service.impl;
+
+import com.hugoserve.metalbroker.domain.entity.MetalEntity;
+import com.hugoserve.metalbroker.domain.repo.MetalRepository;
+import com.hugoserve.metalbroker.service.DbMetalAdminService;
+import jakarta.transaction.Transactional;
+import org.springframework.stereotype.Service;
+
+import org.springframework.cache.annotation.CacheEvict;
+import static com.hugoserve.metalbroker.config.CacheConfig.CACHE_DB_METALS;
+
+
+import java.util.Optional;
+
+@Service
+public class DbMetalAdminServiceImpl implements DbMetalAdminService {
+
+    private final MetalRepository metalRepo;
+
+    public DbMetalAdminServiceImpl(MetalRepository metalRepo) {
+        this.metalRepo = metalRepo;
+    }
+
+    @Override
+    @Transactional
+    @CacheEvict(cacheNames = CACHE_DB_METALS, allEntries = true)
+    public MetalEntity upsert(String code, String name, boolean isActive) {
+        String upper = code.toUpperCase();
+        MetalEntity e = metalRepo.findByCode(upper).orElseGet(MetalEntity::new);
+        e.setCode(upper);
+        e.setName(name);
+        e.setActive(isActive);
+        return metalRepo.save(e);
+    }
+
+    @Override
+    @Transactional
+    @CacheEvict(cacheNames = CACHE_DB_METALS, allEntries = true)
+    public Optional<MetalEntity> update(String code, String nameOrNull, Boolean isActiveOrNull) {
+        return metalRepo.findByCode(code.toUpperCase()).map(e -> {
+            if (nameOrNull != null && !nameOrNull.isBlank()) e.setName(nameOrNull);
+            if (isActiveOrNull != null) e.setActive(isActiveOrNull);
+            return metalRepo.save(e);
+        });
+    }
+
+    @Override
+    @Transactional
+    @CacheEvict(cacheNames = CACHE_DB_METALS, allEntries = true)
+    public Optional<MetalEntity> deactivate(String code) {
+        return metalRepo.findByCode(code.toUpperCase()).map(e -> {
+            e.setActive(false);
+            return metalRepo.save(e);
+        });
+    }
+}
